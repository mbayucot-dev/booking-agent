# Frontend config. The browser talks only to this app's same-origin BFF proxy
# (src/app/api/v1/[...path]); these are SERVER-side env read by that proxy —
# NOT NEXT_PUBLIC, so the token never reaches the browser bundle.

# Backend base URL the proxy forwards to.
BOOKING_AGENT_API_URL=http://localhost:8000

# Bearer token injected on every proxied request. Must match the backend's
# API_AUTH_TOKEN when auth is enabled; leave empty for local/dev (open).
API_AUTH_TOKEN=
