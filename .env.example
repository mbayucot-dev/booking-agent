# Copy to `.env` and fill in. OpenAI and SMTP are OPTIONAL: when a key is absent
# the system uses a deterministic local stand-in, so it runs end-to-end with no
# secrets. Booking data lives in this app's own database (no external API).

# --- OpenAI (booking extraction, cleaner-selection rationale, embeddings) ---
# Without this: extraction uses the deterministic rule parser and the semantic
# preference match is disabled (rules still rank cleaners).
# With it: the real model runs first (rules remain the fallback on any error),
# the LLM narrates the cleaner choice, and cleaner bios + the customer
# preference are embedded for semantic matching.
# Requires the `llm` extra:  pip install -e ".[llm]"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# Cost guardrails: cap output tokens per call and truncate the inbound message
# so a huge paste can't inflate the extraction prompt.
EXTRACTION_MAX_TOKENS=256
SELECTION_MAX_TOKENS=128
MAX_MESSAGE_CHARS=2000

# --- SMTP (confirmation email + calendar invite) ---
# Without SMTP_HOST + MAIL_FROM the email step runs in dry-run mode (records the
# message, sends nothing). Works with any SMTP provider, including Mailgun SMTP:
# set SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587, SMTP_USER=postmaster@<your-domain>.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=bookings@your-domain
# Branding / scheduling used in the email body and the .ics invite.
BUSINESS_NAME=Your Service Team
BUSINESS_TZ=Australia/Brisbane
BOOKING_DURATION_MIN=60
# Availability search window (hours), used when computing free staff slots.
BUSINESS_OPEN_HOUR=8
BUSINESS_CLOSE_HOUR=17

# --- Database (runs, run_events, approvals, audit_logs, customer_memories,
#     plus the booking datastore: staff/clients/contacts/jobs/appointments) ---
# Defaults to a local SQLite file if unset. Provision the schema with:
#   alembic upgrade head
DATABASE_URL=postgresql+psycopg://booking:booking@localhost:5432/booking
# Connection pool + per-query guardrail (Postgres). statement_timeout caps a
# single slow query so it can't pin a pooled connection / run thread.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000

# --- HubSpot CRM (push the contact after the job is confirmed) ---
# Without a token: the contact-sync step runs in dry-run (records, pushes
# nothing). With a token: a HubSpot private-app token creates the contact via
# the CRM v3 API.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com
# Feature flag: set to false to force dry-run even when a token IS set, so the
# whole flow can be exercised standalone without touching HubSpot.
FEATURE_HUBSPOT_SYNC=true

# --- LangSmith (TRACING ONLY — prompts stay in the in-repo registry) ---
# Set the key to trace every LLM call (extraction + cleaner selection) in
# LangSmith. Unset → tracing off (offline dev/tests). Free Developer plan = 1
# seat, ~5k traces/month.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=booking-agent

# --- Runtime / security ---
# "production" hides /docs and /openapi.json (and rejects a CORS wildcard).
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins. Defaults to the local frontend; a "*"
# wildcard is rejected in production and never paired with credentials.
CORS_ORIGINS=http://localhost:3000
# Bearer token for the /runs endpoints. Unset → open (dev). Set it to require
# `Authorization: Bearer <token>` on every run call; the authenticated identity
# (not a client-supplied `by`) is recorded as the approver.
API_AUTH_TOKEN=
# Inbound rate limit on run submission (per client, fixed window). 0 disables.
RATE_LIMIT_RUNS=30
RATE_LIMIT_WINDOW_S=60
